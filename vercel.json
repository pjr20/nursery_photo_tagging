{
  "outputDirectory": ".",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/plants.csv",
      "dest": "/public/plants.csv",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "public, max-age=300"
      }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
